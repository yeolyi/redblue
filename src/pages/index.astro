---
import Layout from "../layouts/Layout.astro";
import LoginCard from "../components/LoginCard.tsx";
import VoteScreen from "../components/VoteScreen.tsx";
import ResultScreen from "../components/ResultScreen.tsx";
import { createSupabaseServerClient } from "../lib/supabase";

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

let myVote: "red" | "blue" | null = null;

if (user) {
  const { data: voteRow } = await supabase
    .from("votes")
    .select("choice")
    .eq("user_id", user.id)
    .maybeSingle();
  if (voteRow) myVote = voteRow.choice as "red" | "blue";
}

const { data: count } = await supabase.rpc("count_votes");
const totalCount = typeof count === "number" ? count : 0;

const authError = Astro.url.searchParams.get("auth");
---

<Layout>
  <main class="relative min-h-screen w-full overflow-hidden">
    {!user && <LoginCard client:load totalCount={totalCount} authError={authError} />}
    {user && import.meta.env.DEV && (
      <script define:vars={{ uid: user.id }} is:inline>
        console.log("user_id:", uid);
      </script>
    )}
    {user && !myVote && <VoteScreen client:load totalCount={totalCount} />}
    {user && myVote && <ResultScreen client:load myVote={myVote} totalCount={totalCount} />}
  </main>
</Layout>
